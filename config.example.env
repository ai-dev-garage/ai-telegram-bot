# Telegram bot (from BotFather)
TELEGRAM_BOT_TOKEN=
# Numeric IDs only (e.g. 123456789 or 123456789,987654321)
ALLOWED_TELEGRAM_USER_IDS=

# App/runtime
# Optional Spring profile (e.g. `local` with application-local.yml overrides — see docs/operator-guide.md)
SPRING_PROFILES_ACTIVE=local
RUNNER_PORT=8765
TELEGRAM_ENABLED=true

# Optional: com.ai.dev.garage.bot logger level (logback-spring.xml). Use DEBUG to trace Telegram dispatch, navigation, API errors.
# LOG_LEVEL_APP_ROOT=DEBUG

# Optional: heap for the Spring Boot process when using ./gradlew bootRun (see gradle.properties bootRunJvmXms/Xmx).
# scripts/run-telegram-runner-local.sh passes these as -P... so they override gradle.properties. Unset = use gradle.properties only.
# BOOTRUN_JVM_XMS=1g
# BOOTRUN_JVM_XMX=1g

# Database (defaults match docker-compose in this repo)
# DB_URL=jdbc:postgresql://localhost:5433/ai_dev_garage_runner
# DB_USER=runner
# DB_PASSWORD=runner

# Optional security between clients and runner API
# RUNNER_AUTH_TOKEN=

# Which external agent CLI handles AGENT_TASK handoff: cursor | claude
AGENT_RUNTIME=cursor

# Pending/result JSON directories (default: ~/.ai-dev-garage/agent-tasks)
# AGENT_TASKS_DIR=

# Optional shared CLI working directory when runtime-specific workspace is unset
# AGENT_CLI_WORKSPACE=/absolute/path/to/workspace

# Cursor CLI (when AGENT_RUNTIME=cursor)
CURSOR_CLI_INVOKE=false
# CURSOR_CLI_WORKSPACE=/absolute/path/to/workspace
# Default workspace if unset: AGENT_CLI_WORKSPACE, then AGENT_TASK_WORKSPACE, then user.home
# AGENT_TASK_WORKSPACE=

# Plan mode prompt suffix (appended to user prompt to encourage structured question formatting)
# CURSOR_PLAN_PROMPT=List each question on its own line ending with '?'. If you want to offer choices, list them as bullet points below the question.

# Claude CLI (when AGENT_RUNTIME=claude)
# CLAUDE_CLI_INVOKE=false
# CLAUDE_CLI_WORKSPACE=/absolute/path/to/workspace

# Claude plan mode (Telegram /plan) — see docs/agent-claude.md
# CLAUDE_PLAN_PROMPT=List each question on its own line ending with '?'. ...
# CLAUDE_PLAN_PERMISSION_MODE=plan
# CLAUDE_PLAN_DANGEROUSLY_SKIP_PERMISSIONS=false
# CLAUDE_PLAN_INCLUDE_PARTIAL_MESSAGES=false
# Optional extra argv for plan invocations only: add under app.claude.plan-extra-args in application.yml (list)

# Shell working directory allowlist (comma-separated absolute paths). Required for /nav, /ls, /cd and non-default cwd.
# Example: ALLOWED_NAVIGATION_PATHS=/Users/me/projects/foo,/Users/me/projects/bar
ALLOWED_NAVIGATION_PATHS=

# Agent task trust (defense in depth). Mirror BOTH in your IDE/agent env when running process-pending-agent-task.
# TASK_AUTH_SECRET_PHRASE — prepended (with trust marker) into pending task intent text; use a unique secret string.
# TASK_AUTH_HMAC_SECRET — shared HMAC-SHA256 key for the "signature" field on pending JSON; leave empty to disable signing.
#   Generate e.g.: openssl rand -hex 32
TASK_AUTH_SECRET_PHRASE=change-me-trusted-phrase
TASK_AUTH_HMAC_SECRET=change-me-hmac-key-min-32-chars-recommended

# Must match the "source" field in pending JSON (default: ai-telegram-bot)
# TASK_SOURCE_ID=ai-telegram-bot

# First line of trusted intent (Spring): APP_RUNNER_TASK_TRUST_MARKER_LINE="[CUSTOM_MARKER]"

# Directory where approved/paused plans are exported as Cursor-compatible .plan.md files (default: ~/.ai-dev-garage/plans)
# PLANS_EXPORT_DIR=~/.ai-dev-garage/plans
